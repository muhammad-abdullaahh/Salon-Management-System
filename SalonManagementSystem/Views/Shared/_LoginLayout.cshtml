<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #f8cdda, #1d2b64);
            font-family: Arial;
        }

        .login-box {
            background: white;
            padding: 40px;
            border-radius: 15px;
            width: 300px;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        button {
            background: #1d2b64;
            color: white;
            border: none;
            padding: 10px;
            width: 100%;
            border-radius: 8px;
        }
    </style>
</head>

<body>
    <div class="login-box">
        @RenderBody()
    </div>
</body>
</html>